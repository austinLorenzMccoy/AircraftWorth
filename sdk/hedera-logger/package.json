{
  "name": "@aircraftworth/hedera-logger",
  "version": "0.1.0",
  "description": "Lightweight Hedera HCS logging and HTS token minting for any Node.js application. Log structured events to Hedera Consensus Service with retry, batching, and async support.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest --testPathPattern=tests/",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm test",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "hedera",
    "hcs",
    "hts",
    "smart-contracts",
    "marketplace",
    "reputation",
    "escrow",
    "aircraft",
    "aviation",
    "blockchain",
    "typescript",
    "consensus",
    "hashgraph",
    "logging",
    "audit-trail",
    "depin",
    "iot"
  ],
  "author": "AircraftWorth <team@aircraftworth.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aircraftworth/hedera-logger"
  },
  "homepage": "https://github.com/aircraftworth/hedera-logger#readme",
  "bugs": {
    "url": "https://github.com/aircraftworth/hedera-logger/issues"
  },
  "peerDependencies": {
    "@hashgraph/sdk": "^2.0.0",
    "ethers": "^5.0.0"
  },
  "devDependencies": {
    "@hashgraph/sdk": "^2.44.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "ethers": "^6.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

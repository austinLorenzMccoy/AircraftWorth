{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true
  },
  "include": [
    "./scripts/**/*",
    "./test/**/*"
  ],
  "exclude": [
    "node_modules"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "typechain/**/*"
  ]
}
